# Copie este arquivo para .env e preencha os valores antes de rodar docker-compose up

# ── Banco de dados ──────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=troque-em-producao
MYSQL_USER=helpdesk
MYSQL_PASSWORD=troque-em-producao

# ── Backend ─────────────────────────────────────────────────────────────────
# Gere um segredo forte: openssl rand -hex 32
JWT_SECRET=troque-em-producao

# Restrinja ao IP/hostname do servidor frontend em produção
CORS_ORIGIN=http://localhost:5173

# ── Funcionalidades opcionais ───────────────────────────────────────────────
FEEDBACK_ENABLED=true
